# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
docker.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# debug/utility scripts that should not be in version control
check_paperlords*.js
check_pages.js
scripts/check-r2.js
config/google-service-account.json
config/*.json
data/processed/upload_manifest.json
scripts/email_send_log.json
test_api.js
test_maths_b_api.py

# pipeline data — R2 + manifests are the source of truth, never commit PDFs
/data/

# local run artifacts / logs
/logs/
/output/
debug_output.txt
m1_*.txt
physics_test.txt
IMPLEMENTATION_STATUS.txt

# Shape-classifier datasets (regenerable via scripts/shape-data-gen.ts)
training-data/

# Supabase data export — contains user PII (emails, OAuth provider IDs, etc.)
# Keep it local, back it up to encrypted private storage, never commit.
data/supabase-export/
__pycache__/
