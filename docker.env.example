# Copy this file to docker.env and fill in real values before building/running.
# NEXT_PUBLIC_* values are also used as Docker build args by docker-compose.yml.

GRADEMAX_PORT=3004
GRADEMAX_PERSIST_DIR=../grademax-persistent

POSTGRES_DB=grademax
POSTGRES_USER=grademax
POSTGRES_PASSWORD=change_me
POSTGRES_DATA_DIR=../postgres_data
DATABASE_URL=postgresql://grademax:change_me@postgres:5432/grademax

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=
SUPER_ADMIN_EMAIL=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=grademax-papers
NEXT_PUBLIC_R2_PUBLIC_URL=

GROQ_API_KEY=
GOOGLE_API_KEY=
INDEXNOW_API_KEY=
CRON_SECRET=

# Optional ingestion scripts may use these names.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=
